{
  "name": "training-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",

    "test": "vitest",
    "coverage": "vitest run --coverage",

    "test:frontend": "vitest --coverage --dir src",
    "test:backend": "vitest --coverage --dir backend",

    "test:login_register": "vitest run --coverage backend/src/middleware/authMiddleware.test.ts src/auth/authFetch.test.ts src/auth/authStore.test.ts src/auth/inactivityTimer.test.ts ",

    "backend:build": "tsc --project backend/tsconfig.json",
    "backend:start": "node backend/src/server.ts"

  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "selfsigned": "^5.5.0",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
